# ── TACHY Cognitive Brain OS V1 ─────────────────────────────────
APP_NAME="TACHY Cognitive AI"
APP_ENV=development          # development | production
APP_HOST=127.0.0.1
APP_PORT=8200

# Guardian / identity
GUARDIAN_NAME="Rohit Kumar"
COMPANY_NAME="TACHY EDTECH PRIVATE LIMITED"
GUARDIAN_TODY_USERNAME=rohitsingh
GUARDIAN_TODY_EMAIL=rohitji.patna@gmail.com
# When true, verified guardian TODY messages can be sent directly by the
# guardian-specific endpoint. Non-guardian messages remain approval-gated.
GUARDIAN_TODY_DIRECT_REPLY=true
# Disabled by default. If enabled later, only verified guardian channels should
# use it until stronger production controls exist.
TODY_SUPERVISED_AUTO_REPLY=false
# Required for the background loop to process messages. Without this exact
# value, app.scripts.tody_worker_loop refuses --live.
TODY_WORKER_LIVE_CONFIRM=
TODY_WORKER_INTERVAL=90
TODY_FAST_REPLY_ENABLED=true
TODY_FAST_REPLY_CONVERSATION_ID=
TODY_FAST_REPLY_INTERVAL=5
TODY_WORKER_ERROR_BACKOFF=1800
TODY_WORKER_RATE_LIMIT_BACKOFF=3600
TODY_TOKEN_PATH=storage/logs/tody_tokens.json
TODY_CHAT_CHUNK_TARGET=240
TODY_TYPING_DELAY_ENABLED=true
TODY_TYPING_DELAY_MIN=0.7
TODY_TYPING_DELAY_MAX=3.0
TODY_TYPING_CHARS_PER_SECOND=120
TODY_NATIVE_TYPING_ENABLED=true
TODY_NATIVE_TYPING_KEEPALIVE_SECONDS=2
TODY_NATIVE_TYPING_PREVIEW=
TODY_PRESENCE_HEARTBEAT_ENABLED=true
# Optional: send Rohit one growth report per UTC day from the live TODY worker.
# Requires --live mode and a verified guardian conversation ID.
TODY_DAILY_GROWTH_REPORT=false
TODY_DAILY_GROWTH_CONVERSATION_ID=
TODY_DAILY_GROWTH_STATE_PATH=storage/logs/tody_daily_growth_report.state
# Optional: send one child-like curiosity check-in per UTC day.
TODY_DAILY_CURIOSITY_MESSAGE=false
TODY_DAILY_CURIOSITY_CONVERSATION_ID=
TODY_DAILY_CURIOSITY_STATE_PATH=storage/logs/tody_daily_curiosity_message.state

# ── Curriculum mastery (CBSE/NCERT foundation to Class XII) ─────
CURRICULUM_LEARNING_ENABLED=true
CURRICULUM_STATE_PATH=storage/logs/curriculum_mastery.json
CURRICULUM_DAILY=true
CURRICULUM_DAILY_STATE_PATH=storage/logs/curriculum_daily.state
OFFLINE_BRAIN_ENABLED=true

# ── Database (MySQL default; PostgreSQL supported) ──────────────
DB_URL="mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/tachy_brain"

# ── LLM provider (modular interface) ────────────────────────────
LLM_PROVIDER=anthropic       # anthropic | huggingface | nvidia | heuristic
LLM_MODEL=claude-opus-4-8
LLM_API_KEY=                 # never commit a real key
HF_TOKEN=                    # Hugging Face token, never commit a real key
HF_MODEL=Qwen/Qwen2.5-72B-Instruct
HF_BASE_URL=https://router.huggingface.co/v1
NVIDIA_API_KEY=              # NVIDIA NIM key, never commit a real key
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_REASONING_BUDGET=16384
NVIDIA_TEMPERATURE=1
NVIDIA_TOP_P=0.95

# ── Safety ──────────────────────────────────────────────────────
# Required in production. Send as: X-API-Key: <value>
INTERNAL_API_KEY=
# Master switch: when true, ALL medium/high-risk actions require approval
SAFETY_ENFORCE=true
# Comma list of action types that always require Rohit's approval
HIGH_RISK_REQUIRE_APPROVAL=true

# ── TODY integration (Phase 1D) ─────────────────────────────────
TODY_API_BASE=https://api.tody.in/api
TODY_EMAIL=
TODY_PASSWORD=

# ── Optional ────────────────────────────────────────────────────
# REDIS_URL=redis://127.0.0.1:6379/0
