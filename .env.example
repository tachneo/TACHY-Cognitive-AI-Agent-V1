# ── TACHY Cognitive Brain OS V1 ─────────────────────────────────
APP_NAME="TACHY Cognitive AI"
APP_ENV=development          # development | production
APP_HOST=127.0.0.1
APP_PORT=8200

# Guardian / identity
GUARDIAN_NAME="Rohit Kumar"
COMPANY_NAME="TACHY EDTECH PRIVATE LIMITED"

# ── Database (MySQL default; PostgreSQL supported) ──────────────
DB_URL="mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/tachy_brain"

# ── LLM provider (modular interface) ────────────────────────────
LLM_PROVIDER=anthropic       # anthropic | glm | local
LLM_MODEL=claude-opus-4-8
LLM_API_KEY=                 # never commit a real key

# ── Safety ──────────────────────────────────────────────────────
# Master switch: when true, ALL medium/high-risk actions require approval
SAFETY_ENFORCE=true
# Comma list of action types that always require Rohit's approval
HIGH_RISK_REQUIRE_APPROVAL=true

# ── TODY integration (Phase 1D) ─────────────────────────────────
TODY_API_BASE=https://api.tody.in/api
TODY_EMAIL=
TODY_PASSWORD=

# ── Optional ────────────────────────────────────────────────────
# REDIS_URL=redis://127.0.0.1:6379/0
